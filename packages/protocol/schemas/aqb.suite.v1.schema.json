{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentquality.dev/schemas/aqb.suite.v1.schema.json",
  "title": "AQB Benchmark Suite v1",
  "type": "object",
  "required": ["protocol_version", "id", "name", "version", "cases", "profile"],
  "properties": {
    "protocol_version": { "const": "aqb.suite.v1" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "license": { "type": "string" },
    "provenance": { "type": "object" },
    "profile": {
      "type": "object",
      "required": ["weights", "minimum_coverage"],
      "properties": {
        "weights": {
          "type": "object",
          "properties": {
            "outcome": { "type": "number", "minimum": 0 },
            "adherence": { "type": "number", "minimum": 0 },
            "tools": { "type": "number", "minimum": 0 },
            "context": { "type": "number", "minimum": 0 },
            "reliability": { "type": "number", "minimum": 0 },
            "safety": { "type": "number", "minimum": 0 },
            "efficiency": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "minimum_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "required_categories": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "readiness_gates": { "type": "array", "items": { "type": "object" } },
    "defaults": { "type": "object" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "input", "evaluators"],
        "properties": {
          "id": { "type": "string" },
          "category": { "type": "string" },
          "input": { "type": "object" },
          "expected": { "type": "object" },
          "tools": { "type": "array", "items": { "type": "object" } },
          "context": { "type": "array", "items": { "type": "object" } },
          "policies": { "type": "array", "items": { "type": "string" } },
          "evaluators": { "type": "array", "items": { "type": "object" } },
          "limits": { "type": "object" },
          "repetitions": { "type": "integer", "minimum": 1, "maximum": 10 },
          "perturbations": { "type": "array", "items": { "type": "object" } },
          "ablations": { "type": "array", "items": { "type": "object" } },
          "tags": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
