{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentquality.dev/schemas/aqb.agent.v1.schema.json",
  "title": "AQB Agent HTTP Protocol v1",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/response" }
  ],
  "$defs": {
    "message": {
      "type": "object",
      "required": ["role", "content"],
      "properties": {
        "role": { "enum": ["system", "developer", "user", "assistant", "tool"] },
        "content": { "type": "string" },
        "name": { "type": "string" },
        "tool_call_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "required": ["event_id", "kind", "started_at"],
      "properties": {
        "event_id": { "type": "string" },
        "parent_event_id": { "type": ["string", "null"] },
        "kind": { "enum": ["agent", "model", "tool", "retrieval", "memory", "guardrail", "error"] },
        "name": { "type": "string" },
        "started_at": { "type": "string", "format": "date-time" },
        "ended_at": { "type": ["string", "null"], "format": "date-time" },
        "input": {},
        "output": {},
        "attributes": { "type": "object" }
      },
      "additionalProperties": false
    },
    "usage": {
      "type": "object",
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cost_usd": { "type": "number", "minimum": 0 },
        "latency_ms": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "request": {
      "type": "object",
      "required": ["protocol_version", "request_id", "case_id", "messages", "limits"],
      "properties": {
        "protocol_version": { "const": "aqb.agent.v1" },
        "request_id": { "type": "string", "minLength": 1 },
        "case_id": { "type": "string", "minLength": 1 },
        "seed": { "type": ["integer", "null"] },
        "messages": { "type": "array", "items": { "$ref": "#/$defs/message" }, "minItems": 1 },
        "tools": { "type": "array", "items": { "type": "object" } },
        "context": { "type": "array", "items": { "type": "object" } },
        "policies": { "type": "array", "items": { "type": "string" } },
        "limits": {
          "type": "object",
          "properties": {
            "timeout_ms": { "type": "integer", "minimum": 1 },
            "max_turns": { "type": "integer", "minimum": 1 },
            "max_cost_usd": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "required": ["protocol_version", "request_id", "status", "output", "events", "usage"],
      "properties": {
        "protocol_version": { "const": "aqb.agent.v1" },
        "request_id": { "type": "string" },
        "status": { "enum": ["succeeded", "failed", "refused", "timed_out"] },
        "output": { "type": "string" },
        "final_state": { "type": "object" },
        "events": { "type": "array", "items": { "$ref": "#/$defs/event" } },
        "usage": { "$ref": "#/$defs/usage" },
        "error": { "type": ["object", "null"] },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    }
  }
}
