# Core service configuration. Copy to .env.local; never commit real secrets.
AQB_ENV=development
AQB_DATABASE_URL=sqlite:///./data/aqb.db
AQB_REDIS_URL=redis://127.0.0.1:6379/0
AQB_EXECUTION_MODE=local
AQB_STORAGE_PATH=./data/artifacts
AQB_MAX_UPLOAD_BYTES=52428800
AQB_MAX_EXTRACTED_BYTES=262144000
AQB_AGENT_ENDPOINT_ALLOWLIST=localhost,127.0.0.1
AQB_ENCRYPTION_KEY=
AQB_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Optional model-assisted judge. Final setup TODO: supply this or another provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_JUDGE_MODEL=gpt-5.6-terra

# Web-to-API routing.
AQB_API_INTERNAL_URL=http://127.0.0.1:8000
NEXT_PUBLIC_AQB_API_PATH=/api/aqb
